<style>
  .radar {
    transform-origin: 512px 216.975px; /* Coordenadas absolutas de la esquina superior izquierda */
    animation: rotateRadar 3s cubic-bezier(0.39, 0.575, 0.565, 1) infinite;
  }

  .radar-clicles {
    animation: radarOpacity 3s cubic-bezier(0.39, 0.575, 0.565, 1) infinite;
  }

  .tag1 {
    animation: tagHightLight 3s cubic-bezier(0.39, 0.575, 0.565, 1) 0.42s
      infinite;
  }
  .tag2 {
    animation: tagHightLight 3s cubic-bezier(0.39, 0.575, 0.565, 1) 0.92s
      infinite;
  }
  .tag3 {
    animation: tagHightLight 3s cubic-bezier(0.39, 0.575, 0.565, 1) 1.5s
      infinite;
  }

  @keyframes tagHightLight {
    from {
      fill: #f0d25b;
      stroke: #fcbc25;
    }

    to {
      fill: #474747;
      stroke: #939393;
    }
  }

  @keyframes rotateRadar {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes radarOpacity {
    0% {
      opacity: 0;
    }
    5% {
      opacity: 1;
    }
    70% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
</style>
