---
interface Props {
  text: string;
  class?: string;
  id?: string;
  bgClass?: string;
}
const { text, class: className, id, bgClass } = Astro.props;
---

<span
  id={id}
  class:list={[
    "bg-gradient-to-br from-primaryText from-20% via-neutral-400 to-neutral-300 to-80%  bg-clip-text leading-tight text-transparent  ",
    className,
  ]}
>
  {text}</span
>
