---
import { Icon } from "astro-icon/components";

interface Props {
  text: string;
  href: string;
  class?: string;
}

const { text, href, class: className } = Astro.props;
---

<a
  href=""
  class:list={[
    "text-primaryText flex items-center justify-center bg-black px-4 py-2 border-neutral-700 border rounded-lg group",
    className,
  ]}
>
  {text}
  <Icon name="arrow-right" class="ml-2 group-hover:translate-x-1 transition" />
</a>
