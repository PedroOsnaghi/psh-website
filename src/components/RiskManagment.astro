---
import Buttom from "@components/Buttom.astro";
import LabelSection from "@components/LabelSection.astro";
import industryService from "@assets/images/industry.webp";
import quimicGraph from "@assets/images/quimic.svg";
import GestionRiesgos from "@assets/graphics/GestionRiesgos.astro";
import { Icon } from "astro-icon/components";
import { HoverBorderGradient } from "./hover-border-gradient";

const dataDescription = [
  {
    title: "Prevención y Evaluación de Riesgos",
    description:
      "Trabajamos en la fase previa para identificar riesgos inherentes a la actividad y peligros que suelen pasar desapercibidos. Evaluamos las probabilidades y consecuencias para desarrollar estrategias que atenúen o eliminen los posibles daños. Colaboramos con los profesionales de Seguridad y Salud Ocupacional (SySO) para confeccionar un plan de emergencias a medida, cubriendo todos los aspectos necesarios para garantizar la seguridad.",
  },
  {
    title: "Formación y Capacitación",
    description:
      "Brindamos capacitaciones especializadas y técnicas para el personal expuesto a zonas de riesgo, asegurando que estén preparados para actuar de manera efectiva. Formamos brigadas de emergencia con los conocimientos y habilidades necesarias para prevenir, minimizar daños y garantizar una respuesta rápida ante cualquier incidente. Nuestro enfoque combina teoría y práctica para maximizar la eficacia.",
  },
  {
    title: "Gestión y Recuperación Post-Incidente",
    description:
      "Implementamos estrategias para administrar recursos y organizar tareas durante el desarrollo de una emergencia, asegurando una gestión eficiente en situaciones críticas. Proponemos estudios y análisis detallados para facilitar una reactivación rápida y ordenada en caso de incidentes. Investigamos las causas de los accidentes y diseñamos planes de mejora para prevenir futuros eventos similares.",
  },
];
---

<section class="section w-screen flex justify-center mt-24 mb-44 relative">
  <div class="xl:w-10/12 w-11/12 2xl:w-[1280px]">
    <header class="w-full text-center mb-16 mx-auto lg:ml-0 lg:mr-0">
      <HoverBorderGradient
        containerClassName="rounded-full mx-auto mb-6 border-neutral-600"
        client:load
      >
        <LabelSection text="Gestión de riesgos" />
      </HoverBorderGradient>
      <h2
        class="mt-3 mb-8 text-4xl lg:text-6xl font-Jakarta font-normal font-heading text-primaryText flex justify-center gap-3 leading-[1.3!important]"
      >
        <span class="section-title">Gestión</span>
        <span class="section-title">deg</span>
        <span
          class="section-title text-transparent bg-gradient-to-br from-neutral-100 via-40% via-pshyellow-80 to-red-500 to-80% bg-[130%_150] bg-clip-text"
          >emergencias
        </span>
        <span
          class="section-title text-transparent bg-gradient-to-br from-neutral-100 via-40% via-pshyellow-80 to-red-500
          to-80% bg-[130%_auto] bg-clip-text"
          >industriales
        </span>
      </h2>
      <p class="mb-6 text-secondaryText text-xl">
        Nuestra formación profesional y trayectoria junto con la experiencia en
        emergencias, permiten la creación de este servicio para brindar
        soluciones concretas, centralizando todo en esta propuesta para su
        beneficio.
      </p>
      <Buttom text="Conocé más" href="#" class="w-max mx-auto" />
    </header>
    <div class="relative">
      <GestionRiesgos class="riesgo-graph w-full" />
    </div>
    <div class="xl:w-12/12 w-11/12 2xl:w-[1280px] mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 mt-16 w-full mx-auto">
        <div class="lg:col-span-6 col-span-1">
          {
            dataDescription.map((item, index) => (
              <section class="features mb-8">
                <div class="flex items-center gap-4">
                  <div class="border border-neutral-300 rounded-md w-6 h-6 flex justify-center items-center text-sm leading-4 text-center font-normal font-Inter text-primaryText bg-gradient-to-br from-pshyellow-80 via-10% via-pshyellow-80 to-red-500 to-70%  ">
                    {index + 1}
                  </div>
                  <h3 class="text-lg font-Jakarta font-medium font-heading text-neutral-200">
                    {item.title}
                  </h3>
                </div>
                <p class="text-secondaryText text-base text-wrap  mt-3">
                  {item.description}
                </p>
              </section>
            ))
          }
        </div>
        <div
          class="lg:col-span-6 col-span-1 border border-neutral-600 bg-gradient-to-b from-bgDark3 to-bgDark2 rounded-md overflow-hidden flex flex-col justify-center items-center"
        >
          <div class="w-full h-[50%] relative">
            <img
              src={quimicGraph.src}
              alt="Industria"
              class="object-cover inline-block h-full scale-110 rounded-lg absolute z-10 transform right-0 translate-x-0 -bottom-2"
            />
            <img
              src={industryService.src}
              alt="Capacitación riesgos quimicos"
              class="object-cover inline-block h-72 rounded-lg absolute transform -translate-x-[80px]"
            />
          </div>

          <div class="text-secondaryText text-base w-full p-12">
            <ul class="flex flex-col gap-5 justify-start w-full">
              <li class="flex items-center gap-2">
                <Icon name="check" class="w-5 h-5 text-pshyellow-80" /> Planes diseñados
                según las normas legales vigentes
              </li>
              <li class="flex items-center gap-2">
                <Icon
                  name="check"
                  class="w-5 h-5 text-pshyellow-80"
                />Instructores certificados
              </li>
              <li class="flex items-center gap-2">
                <Icon
                  name="check"
                  class="w-5 h-5 text-pshyellow-80"
                />Equipamiento de simulación de última generación
              </li>
              <li class="flex items-center gap-2">
                <Icon name="check" class="w-5 h-5 text-pshyellow-80" />Los
                estándares más recientes de la industria
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap/gsap-core";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  gsap.from(".riesgo-graph", {
    scrollTrigger: {
      trigger: ".riesgo-graph",
      start: "top 75%",
    },
    opacity: 0,
    duration: 3,
    ease: "power4.out",
  });

  gsap.from(".features", {
    scrollTrigger: {
      trigger: ".features",
      start: "top 72%",
    },
    x: -100,
    opacity: 0,
    duration: 1.5,
    ease: "power4.out",
    stagger: 0.2,
  });
</script>
